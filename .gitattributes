
# ---- encoding (cognitive-core) ----
# Enforce consistent line endings and encoding across all platforms
# cognitive-core: deterministic UTF-8 + LF (#216)
* text=auto eol=lf
*.sh text eol=lf
*.conf text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.xml text eol=lf
*.txt text eol=lf
*.csv text eol=lf
*.html text eol=lf
*.css text eol=lf
Dockerfile text eol=lf
Makefile text eol=lf
# Binary files — never convert
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# ---- java (cognitive-core) ----
# Java/Spring Boot specific
*.java text eol=lf diff=java
*.kt text eol=lf
*.properties text eol=lf
*.gradle text eol=lf
*.gradle.kts text eol=lf
*.jar binary
*.war binary
*.ear binary
*.class binary
