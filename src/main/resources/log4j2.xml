<?xml version="1.0" encoding="UTF-8"?>
<!--
  Log4J2 configuration. The CLI routes all user-facing output through Log4J2
  (no direct System.out), so the console pattern is a bare message for a clean
  terminal UI. Raise the level or add a file appender for diagnostics if needed.
-->
<Configuration status="WARN">
  <Appenders>
    <Console name="Console" target="SYSTEM_OUT">
      <PatternLayout pattern="%msg%n"/>
    </Console>
  </Appenders>
  <Loggers>
    <Root level="info">
      <AppenderRef ref="Console"/>
    </Root>
  </Loggers>
</Configuration>
