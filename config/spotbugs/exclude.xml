<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs exclusion filter. Add <Match> entries here to suppress known
  false positives. Every suppression should be justified with a comment so it
  can be reviewed and removed once the underlying issue is resolved.
-->
<FindBugsFilter>
  <!-- Example (disabled): ignore a specific false positive.
  <Match>
    <Class name="com.ruzbyte.speedrunner.Example"/>
    <Bug pattern="DM_DEFAULT_ENCODING"/>
  </Match>
  -->

  <!-- CliController is wired with its collaborators (the SpeedrunTimer it drives, the input
       stream, the logger) through constructor injection. Holding those references is the intended
       design of the adapter, not representation exposure. -->
  <Match>
    <Class name="com.ruzbyte.speedrunner.adapters.CliController"/>
    <Bug pattern="EI_EXPOSE_REP2"/>
  </Match>
</FindBugsFilter>
